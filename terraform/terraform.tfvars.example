# =============================================================================
# terraform.tfvars.example — template for new environments
#
# Copy this file to terraform.tfvars and fill in real values.
# This file is safe to commit to version control.
# =============================================================================

# -----------------------------------------------------------------------
# Project & Region
# -----------------------------------------------------------------------
project_id = "thd-workspace"
region     = "us-central1"

# -----------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------
image_tag       = "latest"
service_name    = "patient-appointment"
repository_name = "patient-appointment-repo"

# -----------------------------------------------------------------------
# Infrastructure sizing
# -----------------------------------------------------------------------
cloud_run_cpu    = "1000m"
cloud_run_memory = "512Mi"
cloud_sql_tier   = "db-custom-1-3840"

# -----------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------
vpc_network_name = "polaris-dev-vpc"
vpc_subnet_name  = "polaris-dev-subnet"

# -----------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------
api_gateway_id = "patient-appointment-gateway"

# -----------------------------------------------------------------------
# IAP Access Control
# -----------------------------------------------------------------------
iap_allowed_users = [
  "akhtar-hussain.shaikh@atos.net"
]

iap_allowed_groups = []

iap_service_account = "service-PROJECT_NUMBER@gcp-sa-iap.iam.gserviceaccount.com"

# -----------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------
db_name        = "patient_appointment"
db_user        = "patient_app"
gemini_api_secret_id        = "gemini-api-key"
gemini_api_secret_version   = "latest"
db_password_secret_id       = "patient-db-password"
db_password_secret_version  = "latest"
cloud_run_service_account_id = "patient-appointment-sa"
